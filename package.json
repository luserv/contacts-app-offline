{
  "name": "contacts",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "expo lint",
    "sqlite:init": "node scripts/init-sqlite.mjs",
    "sqlite:seed": "node scripts/init-sqlite.mjs --seed",
    "generate:ico": "node scripts/generate-ico.mjs",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "electron:dev": "cross-env NODE_ENV=development electron electron/main.js",
    "electron:build": "expo export --platform web --output-dir dist && electron-builder --config electron-builder.json",
    "electron:win": "expo export --platform web --output-dir dist && electron-builder --win --config electron-builder.json",
    "electron:mac": "expo export --platform web --output-dir dist && electron-builder --mac --config electron-builder.json",
    "electron:linux": "expo export --platform web --output-dir dist && electron-builder --linux --config electron-builder.json"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.12",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "^16.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.11.0",
    "lucide-react-native": "^0.544.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.3.0",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@electron/rebuild": "^4.0.3",
    "@types/react": "~19.1.10",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "electron": "^32.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.4"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "private": true
}
